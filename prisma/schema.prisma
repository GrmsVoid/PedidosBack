generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MesaEstado {
  LIBRE
  OCUPADA
  UNIDA
}

enum SesionEstado {
  ABIERTA
  CERRADA
  FUGADA
}

enum PedidoEstado {
  CONFIRMADO
  EN_PREPARACION
  LISTO
  ENTREGADO
  CANCELADO
}

enum PedidoOrigen {
  CLIENTE
  MOZO
}

enum MetodoPago {
  EFECTIVO
  YAPE
  POS
}

enum RolCodigo {
  MOZO
  BARISTA
  CAJERO
  ADMIN
}

enum EventoTipo {
  LLAMAR_MOZO
  PEDIR_CUENTA
  MESA_UNIDA
  MESA_SEPARADA
  PEDIDO_CANCELADO
  CIERRE_SIN_PAGO
  PRECIO_CAMBIADO
  ENCUESTA_POST_CIERRE
}

enum EgresoOrigen {
  MANUAL
  PLANILLA
}

enum TipoRemuneracion {
  FIJO_MENSUAL
  POR_HORA
  POR_TURNO
}

enum PlanillaEstado {
  BORRADOR
  CERRADA
}

model Local {
  id             String       @id @default(cuid())
  nombre         String
  ruc            String?
  direccion      String?
  timezone       String       @default("America/Lima")
  qrSigningKeyId String       @default("v1")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  mesas          Mesa[]
  categorias     Categoria[]
  estaciones     Estacion[]
  sesiones       SesionMesa[]
  categoriasGasto   CategoriaGasto[]
  egresos           Egreso[]
  categoriasIngreso CategoriaIngreso[]
  ingresosExtra     IngresoExtra[]
  presupuestos      Presupuesto[]
  planillas         PlanillaPeriodo[]
  preciosDia        PrecioDia[]
  combos            Combo[]
}

model Estacion {
  id        String     @id @default(cuid())
  localId   String
  nombre    String
  activa    Boolean    @default(true)
  local     Local      @relation(fields: [localId], references: [id])
  productos Producto[]
  combos    Combo[]

  @@index([localId, activa])
}

model Mesa {
  id        String            @id @default(cuid())
  localId   String
  codigo    String
  capacidad Int               @default(4)
  posicionX Int               @default(0)
  posicionY Int               @default(0)
  estado    MesaEstado        @default(LIBRE)
  qrToken   String            @unique
  deletedAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  local     Local             @relation(fields: [localId], references: [id])
  sesiones  SesionMesaMesas[]

  @@unique([localId, codigo])
  @@index([localId, estado])
}

model Categoria {
  id        String     @id @default(cuid())
  localId   String
  nombre    String
  orden     Int        @default(0)
  activa    Boolean    @default(true)
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  local     Local      @relation(fields: [localId], references: [id])
  productos Producto[]

  @@index([localId, activa])
}

model Producto {
  id              String               @id @default(cuid())
  categoriaId     String
  estacionId      String
  nombre          String
  descripcion     String?
  imagenUrl       String?
  precioBase      Decimal              @db.Decimal(10, 2)
  prepTimeMinutes Int                  @default(5)
  disponible      Boolean              @default(true)
  orden           Int                  @default(0)
  deletedAt       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  categoria       Categoria            @relation(fields: [categoriaId], references: [id])
  estacion        Estacion             @relation(fields: [estacionId], references: [id])
  grupos          GrupoModificador[]
  items           ItemPedido[]
  historialPrecio ProductoPrecioHist[]
  preciosDia      PrecioDia[]
  comboItems      ComboItem[]

  @@index([categoriaId, disponible])
  @@index([estacionId])
}

model GrupoModificador {
  id           String              @id @default(cuid())
  productoId   String
  nombre       String
  obligatorio  Boolean             @default(false)
  minSeleccion Int                 @default(0)
  maxSeleccion Int                 @default(1)
  orden        Int                 @default(0)
  producto     Producto            @relation(fields: [productoId], references: [id])
  opciones     OpcionModificador[]
}

model OpcionModificador {
  id          String            @id @default(cuid())
  grupoId     String
  nombre      String
  deltaPrecio Decimal           @default(0) @db.Decimal(10, 2)
  disponible  Boolean           @default(true)
  orden       Int               @default(0)
  grupo       GrupoModificador  @relation(fields: [grupoId], references: [id])
  items       ItemModificador[]
}

model ProductoPrecioHist {
  id             String   @id @default(cuid())
  productoId     String
  precioAnterior Decimal  @db.Decimal(10, 2)
  precioNuevo    Decimal  @db.Decimal(10, 2)
  cambiadoPor    String
  cambiadoEn     DateTime @default(now())
  producto       Producto @relation(fields: [productoId], references: [id])

  @@index([productoId, cambiadoEn])
}

model Usuario {
  id           String       @id @default(cuid())
  email        String       @unique
  nombre       String
  pinHash          String?
  passwordHash     String?
  activo           Boolean          @default(true)
  telefono         String?
  tipoRemuneracion TipoRemuneracion @default(FIJO_MENSUAL)
  sueldoMensual    Decimal?         @db.Decimal(10, 2)
  tarifaHora       Decimal?         @db.Decimal(10, 2)
  montoTurno       Decimal?         @db.Decimal(10, 2)
  deletedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  roles            UsuarioRol[]
  turnos           Turno[]
}

model Rol {
  id       String       @id @default(cuid())
  codigo   RolCodigo    @unique
  usuarios UsuarioRol[]
}

model UsuarioRol {
  usuarioId String
  rolId     String
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  rol       Rol     @relation(fields: [rolId], references: [id])

  @@id([usuarioId, rolId])
}

model SesionMesa {
  id                 String            @id @default(cuid())
  localId            String
  abiertaEn          DateTime          @default(now())
  cerradaEn          DateTime?
  cerradaPor         String?
  estado             SesionEstado      @default(ABIERTA)
  encuestaSolicitada Boolean           @default(false)
  local              Local             @relation(fields: [localId], references: [id])
  mesas              SesionMesaMesas[]
  pedidos            Pedido[]
  pagos              Pago[]
  eventos            EventoSesion[]
  encuesta           Encuesta?

  @@index([localId, estado, abiertaEn])
}

model SesionMesaMesas {
  sesionId String
  mesaId   String
  sesion   SesionMesa @relation(fields: [sesionId], references: [id])
  mesa     Mesa       @relation(fields: [mesaId], references: [id])

  @@id([sesionId, mesaId])
  @@index([mesaId])
}

model Pedido {
  id                    String       @id @default(cuid())
  sesionId              String
  numeroSesion          Int
  origen                PedidoOrigen
  creadoPor             String?
  confirmadoEn          DateTime     @default(now())
  preparacionIniciadaEn DateTime?
  listoEn               DateTime?
  entregadoEn           DateTime?
  canceladoEn           DateTime?
  canceladoMotivo       String?
  estado                PedidoEstado @default(CONFIRMADO)
  sesion                SesionMesa   @relation(fields: [sesionId], references: [id])
  items                 ItemPedido[]

  @@unique([sesionId, numeroSesion])
  @@index([estado, confirmadoEn])
}

model ItemPedido {
  id                      String            @id @default(cuid())
  pedidoId                String
  productoId              String?
  comboId                 String?
  nombreCongelado         String?
  cantidad                Int
  precioUnitarioCongelado Decimal           @db.Decimal(10, 2)
  prepTimeCongelado       Int               @default(0)
  notaLibre               String?
  estacionIdCongelada     String
  pedido                  Pedido            @relation(fields: [pedidoId], references: [id])
  producto                Producto?         @relation(fields: [productoId], references: [id])
  combo                   Combo?            @relation(fields: [comboId], references: [id])
  modificadores           ItemModificador[]

  @@index([pedidoId])
  @@index([estacionIdCongelada])
}

model ItemModificador {
  id                   String            @id @default(cuid())
  itemPedidoId         String
  opcionId             String
  nombreCongelado      String
  deltaPrecioCongelado Decimal           @db.Decimal(10, 2)
  itemPedido           ItemPedido        @relation(fields: [itemPedidoId], references: [id])
  opcion               OpcionModificador @relation(fields: [opcionId], references: [id])

  @@index([itemPedidoId])
}

model Pago {
  id           String     @id @default(cuid())
  sesionId     String
  metodo       MetodoPago
  monto        Decimal    @db.Decimal(10, 2)
  cajeroId     String
  comensalNum  Int?
  registradoEn DateTime   @default(now())
  sesion       SesionMesa @relation(fields: [sesionId], references: [id])

  @@index([sesionId])
}

model EventoSesion {
  id             String     @id @default(cuid())
  sesionId       String
  tipo           EventoTipo
  payloadJson    Json?
  atendido       Boolean    @default(false)
  atendidoPor    String?
  atendidoEn     DateTime?
  actorUsuarioId String?
  actorIp        String?
  creadoEn       DateTime   @default(now())
  sesion         SesionMesa @relation(fields: [sesionId], references: [id])

  @@index([sesionId, tipo, atendido])
}

model Encuesta {
  id         String     @id @default(cuid())
  sesionId   String     @unique
  estrellas  Int
  comentario String?
  creadaEn   DateTime   @default(now())
  sesion     SesionMesa @relation(fields: [sesionId], references: [id])
}

model IdempotencyKey {
  key            String   @id
  endpoint       String
  responseStatus Int
  responseBody   Json
  creadaEn       DateTime @default(now())
  expiraEn       DateTime

  @@index([expiraEn])
}

// ---------- Finanzas (Fase A) ----------

model CategoriaGasto {
  id        String    @id @default(cuid())
  localId   String
  nombre    String
  activa    Boolean   @default(true)
  orden     Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  local        Local         @relation(fields: [localId], references: [id])
  egresos      Egreso[]
  presupuestos Presupuesto[]

  @@index([localId, activa])
}

model Egreso {
  id          String         @id @default(cuid())
  localId     String
  categoriaId String
  monto       Decimal        @db.Decimal(10, 2)
  fecha       DateTime
  descripcion String?
  origen      EgresoOrigen   @default(MANUAL)
  creadoPor   String?
  createdAt   DateTime       @default(now())
  local       Local          @relation(fields: [localId], references: [id])
  categoria   CategoriaGasto @relation(fields: [categoriaId], references: [id])

  @@index([localId, fecha])
  @@index([categoriaId])
}

model CategoriaIngreso {
  id        String         @id @default(cuid())
  localId   String
  nombre    String
  activa    Boolean        @default(true)
  orden     Int            @default(0)
  deletedAt DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  local     Local          @relation(fields: [localId], references: [id])
  ingresos  IngresoExtra[]

  @@index([localId, activa])
}

model IngresoExtra {
  id          String           @id @default(cuid())
  localId     String
  categoriaId String
  monto       Decimal          @db.Decimal(10, 2)
  fecha       DateTime
  descripcion String?
  creadoPor   String?
  createdAt   DateTime         @default(now())
  local       Local            @relation(fields: [localId], references: [id])
  categoria   CategoriaIngreso @relation(fields: [categoriaId], references: [id])

  @@index([localId, fecha])
  @@index([categoriaId])
}

// Presupuesto mensual por categoría de gasto (Fase B).
model Presupuesto {
  id          String         @id @default(cuid())
  localId     String
  categoriaId String
  anio        Int
  mes         Int
  montoLimite Decimal        @db.Decimal(10, 2)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  local       Local          @relation(fields: [localId], references: [id])
  categoria   CategoriaGasto @relation(fields: [categoriaId], references: [id])

  @@unique([localId, categoriaId, anio, mes])
  @@index([localId, anio, mes])
}

// Planilla mensual (Fase D): se calcula desde turnos + remuneración y al cerrar genera un Egreso.
model PlanillaPeriodo {
  id         String          @id @default(cuid())
  localId    String
  anio       Int
  mes        Int
  estado     PlanillaEstado  @default(CERRADA)
  total      Decimal         @db.Decimal(10, 2)
  egresoId   String?
  generadoEn DateTime        @default(now())
  local      Local           @relation(fields: [localId], references: [id])
  lineas     PlanillaLinea[]

  @@unique([localId, anio, mes])
}

model PlanillaLinea {
  id               String           @id @default(cuid())
  periodoId        String
  usuarioId        String
  nombre           String
  tipoRemuneracion TipoRemuneracion
  base             Decimal          @db.Decimal(10, 2)
  turnos           Int              @default(0)
  horas            Decimal          @default(0) @db.Decimal(10, 2)
  monto            Decimal          @db.Decimal(10, 2)
  periodo          PlanillaPeriodo  @relation(fields: [periodoId], references: [id], onDelete: Cascade)

  @@index([periodoId])
}

// Precio especial de un producto para una fecha (Fase E: menú del día / promo).
model PrecioDia {
  id         String   @id @default(cuid())
  localId    String
  productoId String
  precio     Decimal  @db.Decimal(10, 2)
  fecha      DateTime @db.Date
  createdAt  DateTime @default(now())
  local      Local    @relation(fields: [localId], references: [id])
  producto   Producto @relation(fields: [productoId], references: [id])

  @@unique([productoId, fecha])
  @@index([localId, fecha])
}

// Combo: varios productos a precio fijo (Fase E).
model Combo {
  id          String      @id @default(cuid())
  localId     String
  estacionId  String
  nombre      String
  descripcion String?
  precio      Decimal     @db.Decimal(10, 2)
  disponible  Boolean     @default(true)
  orden       Int         @default(0)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  local       Local       @relation(fields: [localId], references: [id])
  estacion    Estacion    @relation(fields: [estacionId], references: [id])
  items       ComboItem[]
  pedidoItems ItemPedido[]

  @@index([localId, disponible])
}

model ComboItem {
  id         String   @id @default(cuid())
  comboId    String
  productoId String
  cantidad   Int      @default(1)
  combo      Combo    @relation(fields: [comboId], references: [id], onDelete: Cascade)
  producto   Producto @relation(fields: [productoId], references: [id])

  @@index([comboId])
}

// Turno planificado de un miembro del staff (Fase C).
model Turno {
  id         String   @id @default(cuid())
  usuarioId  String
  fecha      DateTime @db.Date
  horaInicio String
  horaFin    String
  nota       String?
  createdAt  DateTime @default(now())
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([fecha])
}
